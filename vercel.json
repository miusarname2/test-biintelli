{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "public": false,
  "functions": {
    "api/**/*.ts": {
      "memory": 2048,
      "maxDuration": 60
    }
  },
  "env": {
    "NODE_ENV": "production"
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api"
    }
  ]
}
